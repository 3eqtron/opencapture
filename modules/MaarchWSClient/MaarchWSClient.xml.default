<?xml version="1.0" encoding="UTF-8"?>
<MaarchWSClient>
	<WSDL name="maarch_entreprise" uri="http://127.0.0.1/mep14/ws_server.php?WSDL" cacheUse="0" SSL="false" >
		<proxy>
			<user>superadmin</user>
			<pass>superadmin</pass>
			<timeout>600</timeout>
		</proxy>
	</WSDL>
  <process name="OMT_OPS" >
		<loop xpath="/Batch/Documents/Document">
			<call name="storeResourceFromURI" >
				<argument name="fileURI" xvalue="@fileToImport" />
        <argument name="data">
					<column>type_id</column>
					<value>400</value>
					<type>integer</type>
				</argument>
        <argument name="data">
					<column>scan_date</column>
					<value xvalue="@creationdate" />
					<type>date</type>
				</argument>
        <argument name="data">
					<column>origin</column>
					<value xvalue="@origin" />
					<type>string</type>
				</argument>
        <argument name="data">
					<column>scan_wkstation</column>
					<value xvalue="@wkStation" />
					<type>string</type>
				</argument>
        <argument name="data">
					<column>custom_t1</column>
					<value xvalue="@customerid" />
					<type>string</type>
				</argument>
        <argument name="data">
					<column>custom_t9</column>
					<value xvalue="@doctype" />
					<type>string</type>
				</argument>
				<argument name="data">
					<column>identifier</column>
					<value xvalue="@filename" />
					<type>string</type>
				</argument>
				<argument name="data">
					<column>typist</column>
					<value>ws</value>
					<type>string</type>
				</argument>
				<argument name="data">
					<column>doc_date</column>
					<value xvalue="@docdate" />
					<type>date</type>
				</argument>
				<argument name="data">
					<column>custom_t10</column>
					<value xvalue="@barcodeOPS" />
					<type>string</type>
				</argument>
        <argument name="data">
					<column>policy_id</column>
					<value>FNTC</value>
					<type>string</type>
				</argument>
        <argument name="data">
					<column>cycle_id</column>
					<value>INIT</value>
					<type>string</type>
				</argument>
				<argument name="collId">res_coll</argument>
				<argument name="table" >res_x</argument>
				<argument name="format">pdf</argument>
				<argument name="status">ATT</argument>
				<return>
					<resId metadata="resId" />
				</return>
			</call>
			<!--loop xpath="./Pages/Page">
        <call name="setResPage" >
          <argument name="collId">res_coll</argument>
          <argument name="resId" xvalue="ancestor::Document/Metadata/resId" />
